generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================
// 1. ENUMS
// ==============================

enum SystemRole {
  ADMIN
  MANAGER
}

enum ClientStatus {
  prospect
  onHold
  paymentVerification
  reserved
  underNego
  rejected
  success

  @@map("client_status_enum")
}

enum UnitStatus {
  available
  onHold    // Unit is claimed by a public reservation — awaiting payment confirmation
  reserved
  underNego
  occupied

  @@map("unit_status_enum")
}

enum ReservationStatus {
  pending           // Customer submitted — unit is onHold, 48hr clock running
  paymentSubmitted  // Customer uploaded proof — awaiting manager verification
  confirmed         // Manager verified — Client record auto-created, unit → reserved
  expired           // 48hr elapsed with no payment — unit released back to available
  cancelled         // Manually cancelled by manager

  @@map("reservation_status_enum")
}

// ==============================
// 2. ACCOUNTS
// ==============================

model SystemAccount {
  id        Int        @id @default(autoincrement()) @map("accountID")
  email     String     @unique
  password  String
  firstName String?
  lastName  String?
  contactNo String?
  role      SystemRole @default(MANAGER)
  createdAt DateTime   @default(now())

  // Agents/brokers this account manages
  brokersManaged Broker[] @relation("ManagerToBroker")

  // Clients this account created / is handling
  clientsManaged Client[] @relation("AccountToClient")

  // Reservations this account verified (payment confirmation)
  verificationsHandled Reservation[] @relation("VerifiedByAccount")

  @@map("system_accounts")
}

// ==============================
// 3. BROKERS
// A profile-only entity managed by a SystemAccount.
// No login. No connection to clients.
// Renamed @map from "userID" → "brokerID" to reflect its actual role.
// NOTE: Run `prisma migrate` after this change — it renames the column in the DB.
// ==============================

model Broker {
  id                    Int       @id @default(autoincrement()) @map("brokerID")
  firstName             String?
  lastName              String?
  middleName            String?
  birthDate             DateTime? @db.Date
  homeAddress           String?
  email                 String?   @unique
  employerName          String?
  position              String?
  businessAddress       String?
  brokersLicense        String?
  tin                   String?
  primaryContact        String?
  viber                 String?
  whatsapp              String?
  messenger             String?
  emergencyContactName  String?
  emergencyContactNo    String?
  emergencyRelationship String?
  isDeleted             Int       @default(0) @db.SmallInt

  // Which SystemAccount manages this broker
  managerId Int?           @map("managerID")
  manager   SystemAccount? @relation("ManagerToBroker", fields: [managerId], references: [id])

  // Profile detail relations (unchanged)
  brokerPictures      BrokersPicture[]
  educBackgrounds     EducBackground[]
  salesExperiences    SalesExperience[]
  seminars            Seminar[]
  characterReferences CharacterReference[]

  @@map("broker")
}

// ==============================
// 4. CLIENTS
// 100% owned by a SystemAccount (manager or admin).
// brokerId removed — that was a leftover from the old 3-role system.
// ==============================

model Client {
  id           Int          @id @default(autoincrement()) @map("clientID")
  firstName    String?
  lastName     String?
  email        String?
  clientStatus ClientStatus @default(prospect) @map("client_status")

  // The SystemAccount (manager/admin) who owns this client
  accountId Int?           @map("accountID")
  account   SystemAccount? @relation("AccountToClient", fields: [accountId], references: [id])

  // Unit the client is interested in / has reserved
  unitId Int?  @map("unit_id")
  unit   Unit? @relation(fields: [unitId], references: [id])

  // If this client was auto-created from a public reservation, link it here
  reservation Reservation?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("clientstable")
}

// ==============================
// 5. UNITS
// ==============================

model Unit {
  id                  Int        @id @default(autoincrement()) @map("unit_id")
  unitType            String?    @map("unit_type")
  roomNo              String?    @map("room_no")
  size                String?
  floor               Int?
  installmentPerMonth Decimal?   @map("installment_per_month") @db.Decimal(10, 2)
  price               Decimal?   @db.Decimal(15, 2)
  unitStatus          UnitStatus @default(available) @map("unit_status")

  clients      Client[]
  unitPictures UnitPicture[]
  reservations Reservation[]

  @@map("unit_tbl")
}

model UnitPicture {
  id        Int     @id @default(autoincrement()) @map("imageID")
  imagePath String?
  unitId    Int?    @map("unit_id")
  unit      Unit?   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@map("unit_pictures")
}

// ==============================
// 6. RESERVATIONS (NEW)
//
// Created when a customer clicks "Reserve" on the marketing site.
//
// Flow:
//   1. Customer submits Gmail on marketing site
//      → Reservation created (status: pending)
//      → Unit status → onHold
//      → Email sent with reservationId + token (for secure status lookup)
//
//   2a. Customer returns, uploads payment proof
//       → paymentProofPath set, status → paymentSubmitted
//
//   2b. 48 hours pass with no proof
//       → Cron job in api/: status → expired, unit → available
//
//   3. Manager verifies payment in system dashboard
//      → status → confirmed
//      → Client record auto-created (clientId set here)
//      → Unit status → reserved
//      → verifiedBy + verifiedAt recorded
// ==============================

model Reservation {
  id     Int    @id @default(autoincrement()) @map("reservationID")

  // Secure lookup token — random 32-char string generated at creation.
  // Sent to customer via email. Required (alongside email) for status lookup.
  // Never expose auto-increment IDs as the sole lookup key.
  token  String @unique @map("reservation_token")

  // Customer contact — collected from the marketing reservation form
  customerEmail     String  @map("customer_email")
  customerFirstName String? @map("customer_first_name")
  customerLastName  String? @map("customer_last_name")
  customerContact   String? @map("customer_contact")

  status ReservationStatus @default(pending)

  // Which unit was reserved
  unitId Int  @map("unit_id")
  unit   Unit @relation(fields: [unitId], references: [id])

  // Auto-created Client record (set when manager confirms payment)
  clientId Int?    @unique @map("clientID")
  client   Client? @relation(fields: [clientId], references: [id])

  // Timestamps
  reservedAt  DateTime  @default(now()) @map("reserved_at")

  // Set at creation: reservedAt + 48 hours
  // Cron job checks this to auto-expire
  expiresAt   DateTime  @map("expires_at")

  // Payment proof — file path on the same server (like broker/unit pictures)
  paymentProofPath    String?   @map("payment_proof_path")
  paymentSubmittedAt  DateTime? @map("payment_submitted_at")

  // Manager verification
  verifiedAt  DateTime?      @map("verified_at")
  verifiedById Int?          @map("verified_by_account_id")
  verifiedBy   SystemAccount? @relation("VerifiedByAccount", fields: [verifiedById], references: [id])

  // Optional: manager notes on verification
  verificationNotes String? @map("verification_notes")

  @@map("reservations")
}

// ==============================
// 7. BROKER DETAILS
// Unchanged — profile data for broker records.
// ==============================

model BrokersPicture {
  id        Int     @id @default(autoincrement()) @map("imageID")
  imagePath String?
  brokerId  Int?    @map("brokerID")
  broker    Broker? @relation(fields: [brokerId], references: [id])

  @@map("brokerspicture")
}

model EducBackground {
  id             Int     @id @default(autoincrement()) @map("educID")
  highSchool     String?
  highSchoolYear String?
  collegeDegree  String?
  collegeYear    String?
  brokerId       Int?    @map("brokerID")
  broker         Broker? @relation(fields: [brokerId], references: [id])

  @@map("educbackground")
}

model SalesExperience {
  id       Int     @id @default(autoincrement()) @map("experienceID")
  company  String?
  position String?
  years    String?
  brokerId Int?    @map("brokerID")
  broker   Broker? @relation(fields: [brokerId], references: [id])

  @@map("salesexperience")
}

model CharacterReference {
  id           Int     @id @default(autoincrement()) @map("referenceID")
  name         String?
  relationship String?
  contactNo    String?
  email        String?
  brokerId     Int?    @map("brokerID")
  broker       Broker? @relation(fields: [brokerId], references: [id])

  @@map("characterreference")
}

model Seminar {
  id       Int       @id @default(autoincrement()) @map("seminar_id")
  seminars String?
  semDate  DateTime? @map("sem_date") @db.Date
  venue    String?
  brokerId Int?      @map("brokerID")
  broker   Broker?   @relation(fields: [brokerId], references: [id])

  @@map("seminarstable")
}
