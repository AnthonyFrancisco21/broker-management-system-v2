  generator client {
    provider = "prisma-client-js"
  }

  datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
  }

  // ==============================
  // 1. ENUMS
  // ==============================

  enum SystemRole {
    ADMIN
    MANAGER
  }

  enum ClientStatus {
    prospect
    onHold
    paymentVerification
    reserved
    underNego
    rejected
    success

    @@map("client_status_enum")
  }

  enum UnitStatus {
    available
    onHold
    reserved
    underNego
    occupied

    @@map("unit_status_enum")
  }

  enum ReservationStatus {
    pending
    paymentSubmitted
    confirmed
    expired
    cancelled

    @@map("reservation_status_enum")
  }

  // ==============================
  // 2. ACCOUNTS
  // ==============================

  model SystemAccount {
    id        Int        @id @default(autoincrement()) @map("accountID")
    email     String     @unique
    password  String
    firstName String?
    lastName  String?
    contactNo String?
    role      SystemRole @default(MANAGER)
    createdAt DateTime   @default(now())

    brokersManaged       Broker[]      @relation("ManagerToBroker")
    clientsManaged       Client[]      @relation("AccountToClient")
    verificationsHandled Reservation[] @relation("VerifiedByAccount")

    @@map("system_accounts")
  }

  // ==============================
  // 3. BROKERS
  // ==============================

  model Broker {
    id                    Int       @id @default(autoincrement()) @map("brokerID")
    firstName             String?
    lastName              String?
    middleName            String?
    birthDate             DateTime? @db.Date
    homeAddress           String?
    email                 String?   @unique
    employerName          String?
    position              String?
    businessAddress       String?
    brokersLicense        String?
    tin                   String?
    primaryContact        String?
    viber                 String?
    whatsapp              String?
    messenger             String?
    emergencyContactName  String?
    emergencyContactNo    String?
    emergencyRelationship String?
    isDeleted             Int       @default(0) @db.SmallInt

    managerId Int?           @map("managerID")
    manager   SystemAccount? @relation("ManagerToBroker", fields: [managerId], references: [id])

    brokerPictures      BrokersPicture[]
    educBackgrounds     EducBackground[]
    salesExperiences    SalesExperience[]
    seminars            Seminar[]
    characterReferences CharacterReference[]

    @@map("broker")
  }

  // ==============================
  // 4. CLIENTS
  // ==============================

  model Client {
    id           Int          @id @default(autoincrement()) @map("clientID")
    firstName    String?
    lastName     String?
    email        String?
    clientStatus ClientStatus @default(prospect) @map("client_status")

    accountId Int?           @map("accountID")
    account   SystemAccount? @relation("AccountToClient", fields: [accountId], references: [id])

    unitId Int?  @map("unit_id")
    unit   Unit? @relation(fields: [unitId], references: [id])

    reservation     Reservation?
    clientDocuments ClientDocument[]

    createdAt DateTime @default(now()) @map("created_at")

    @@map("clientstable")
  }

  // ─── Client Documents ─────────────────────────────────────────────────────────
  // Stores file paths for files uploaded against a client record.
  // Same pattern as BrokersPicture and UnitPicture — only the path is stored,
  // the actual file lives in the api/uploads folder.
  // The manager uploads these on behalf of the client (IDs, contracts, etc.)

  model ClientDocument {
    id         Int      @id @default(autoincrement()) @map("documentID")
    filePath   String?  @map("file_path")
    // Optional label so the manager knows what the file is
    // e.g. "Valid ID", "Proof of Income", "Certificate of Employment"
    label      String?
    uploadedAt DateTime @default(now()) @map("uploaded_at")

    clientId Int?    @map("clientID")
    client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

    @@map("client_documents")
  }

  // ==============================
  // 5. UNITS
  // ==============================

  model Unit {
    id                  Int        @id @default(autoincrement()) @map("unit_id")
    unitType            String?    @map("unit_type")
    roomNo              String?    @map("room_no")
    size                String?
    floor               Int?
    installmentPerMonth Decimal?   @map("installment_per_month") @db.Decimal(10, 2)
    price               Decimal?   @db.Decimal(15, 2)
    unitStatus          UnitStatus @default(available) @map("unit_status")

    clients      Client[]
    unitPictures UnitPicture[]
    reservations Reservation[]

    @@map("unit_tbl")
  }

  model UnitPicture {
    id        Int     @id @default(autoincrement()) @map("imageID")
    imagePath String?
    unitId    Int?    @map("unit_id")
    unit      Unit?   @relation(fields: [unitId], references: [id], onDelete: Cascade)

    @@map("unit_pictures")
  }

  // ==============================
  // 6. RESERVATIONS
  // ==============================

  model Reservation {
    id    Int    @id @default(autoincrement()) @map("reservationID")
    token String @unique @map("reservation_token")

    customerEmail     String  @map("customer_email")
    customerFirstName String? @map("customer_first_name")
    customerLastName  String? @map("customer_last_name")
    customerContact   String? @map("customer_contact")

    status ReservationStatus @default(pending)

    unitId Int  @map("unit_id")
    unit   Unit @relation(fields: [unitId], references: [id])

    clientId Int?    @unique @map("clientID")
    client   Client? @relation(fields: [clientId], references: [id])

    reservedAt DateTime @default(now()) @map("reserved_at")
    expiresAt  DateTime @map("expires_at")

    paymentProofPath   String?   @map("payment_proof_path")
    paymentSubmittedAt DateTime? @map("payment_submitted_at")

    verifiedAt   DateTime?      @map("verified_at")
    verifiedById Int?           @map("verified_by_account_id")
    verifiedBy   SystemAccount? @relation("VerifiedByAccount", fields: [verifiedById], references: [id])

    verificationNotes String? @map("verification_notes")

    @@map("reservations")
  }

  // ==============================
  // 7. BROKER DETAILS
  // ==============================

  model BrokersPicture {
    id        Int     @id @default(autoincrement()) @map("imageID")
    imagePath String?
    brokerId  Int?    @map("brokerID")
    broker    Broker? @relation(fields: [brokerId], references: [id])

    @@map("brokerspicture")
  }

  model EducBackground {
    id             Int     @id @default(autoincrement()) @map("educID")
    highSchool     String?
    highSchoolYear String?
    collegeDegree  String?
    collegeYear    String?
    brokerId       Int?    @map("brokerID")
    broker         Broker? @relation(fields: [brokerId], references: [id])

    @@map("educbackground")
  }

  model SalesExperience {
    id       Int     @id @default(autoincrement()) @map("experienceID")
    company  String?
    position String?
    years    String?
    brokerId Int?    @map("brokerID")
    broker   Broker? @relation(fields: [brokerId], references: [id])

    @@map("salesexperience")
  }

  model CharacterReference {
    id           Int     @id @default(autoincrement()) @map("referenceID")
    name         String?
    relationship String?
    contactNo    String?
    email        String?
    brokerId     Int?    @map("brokerID")
    broker       Broker? @relation(fields: [brokerId], references: [id])

    @@map("characterreference")
  }

  model Seminar {
    id       Int       @id @default(autoincrement()) @map("seminar_id")
    seminars String?
    semDate  DateTime? @map("sem_date") @db.Date
    venue    String?
    brokerId Int?      @map("brokerID")
    broker   Broker?   @relation(fields: [brokerId], references: [id])

    @@map("seminarstable")
  }
