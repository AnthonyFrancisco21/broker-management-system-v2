{
  "name": "broker-system",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:system\" \"npm run dev:marketing\"",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:system": "npm --prefix apps/system run dev",
    "dev:marketing": "npm --prefix apps/marketing run dev",
    "postinstall": "npx prisma generate --schema=packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.7.4",
    "prisma": "^7.4.1",
    "turbo": "^2.8.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^7.4.1"
  }
}
